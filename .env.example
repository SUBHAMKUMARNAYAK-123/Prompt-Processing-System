# ──────────────────────────────────────────────
# AI Prompt Queue — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# LLM Provider Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Redis
REDIS_URL=redis://localhost:6379

# Queue Settings
QUEUE_NAME=prompt-queue
WORKER_CONCURRENCY=4          # Parallel jobs per worker process
MAX_RETRIES=3
JOB_TIMEOUT_SECONDS=60
JOB_STALL_INTERVAL_MS=30000

# Rate Limiting
RATE_LIMIT_RPM=300            # Max LLM requests per minute (shared across all workers)

# Semantic Cache
CACHE_SIMILARITY_THRESHOLD=0.95   # 0.0 = cache everything, 1.0 = exact match only
CACHE_TTL_SECONDS=86400           # 24 hours

# API Security (optional)
REQUIRE_API_KEY=false
API_KEY_HEADER=X-API-Key

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]
